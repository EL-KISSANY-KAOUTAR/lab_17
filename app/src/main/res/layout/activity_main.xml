<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#111111"
    android:padding="24dp"
    android:gravity="center">

    <!-- Titre -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ReceiverDemo"
        android:textColor="#FF6B00"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BroadcastReceiver Lab"
        android:textColor="#888888"
        android:textSize="13sp"
        android:layout_marginBottom="40dp"/>

    <!-- Carte statut -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STATUT"
        android:textColor="#FF6B00"
        android:textSize="11sp"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv__Statussss"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Receiver Mode Avion : DESACTIVE"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="16dp"
        android:background="#1A1A1A"
        android:layout_marginBottom="32dp"/>

    <!-- Bouton 1 — plein orange -->
    <Button
        android:id="@+id/btn_Toggle_Airplaneee"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Activer Receiver Avion"
        android:textColor="#FFFFFF"
        android:backgroundTint="#FF6B00"
        android:textSize="15sp"
        android:layout_marginBottom="12dp"/>

    <!-- Bouton 2 — fond sombre -->
    <Button
        android:id="@+id/boutton_Send_Custom"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="Envoyer Custom Broadcast"
        android:textColor="#FF6B00"
        android:backgroundTint="#2A2A2A"
        android:textSize="15sp"/>

</LinearLayout>